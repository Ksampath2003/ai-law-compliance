# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/ai_law_compliance

# ─────────────────────────────────────────────
# LLM
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─────────────────────────────────────────────
# Vector Store (choose one)
# ─────────────────────────────────────────────
USE_LOCAL_VECTOR_DB=true           # true = use ChromaDB locally, false = Pinecone

# Pinecone (only if USE_LOCAL_VECTOR_DB=false)
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX=ai-laws

# ─────────────────────────────────────────────
# API Security
# ─────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-secret-key
API_KEY_HEADER=X-API-Key
ADMIN_API_KEY=change-me-admin-key

# ─────────────────────────────────────────────
# App Config
# ─────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000
